@article{noauthor_joint_2002,
	title = {Joint Services Conference on the Uses of History for Analysis and Military Planning ({JCHAMP})},
	volume = {7},
	doi = {10.5711/morj.7.3.47},
	abstract = {[abstract based on the first two paragraphs] This paper is an electronically scanned version of a presentation by Clay Thomas at the {JCHAMP} in 1987. Mr. Walt Hollis, {FS}, Deputy Under Secretary of the Army (Operations Research), sponsored the {JCHAMP} to explore the uses of military historical data for analysis and operational planning. {JCHAMP} was held April 2830, 1987, at the National Defense University, Washington, {DC}. According to the executive summary of the {JCHAMP} report, There has been a feeling for quite some time among the analytic community within the military that there were vast amounts of historical data available that might be of use to them in their modeling and statistical analyses. Mr. Hollis had written to several Army analysts earlier in a April 1982 memo, The time may be ripe for the Army community to get its act together on what to do about historical data. According to Mr. Hollis, {JCHAMP} made a start.These notions are still relevant today. With all the reports generated after Desert Storm, Operation Allied Force, and a multitude of operations other than war, we have an abundance of historical data. However, we in the military operations research community still face the challenge to get our act together on what to do about historical data. Gene Visco, {FS}, commented after reading Clayton's paper, Little progress has been made to institutionalize and make adequate use of military experiences (history) in today's operations analysis. It is a sorry commentary to note that, in this era of heavyalmost totalemphasis on digital computer modeling of military operations, almost no attention is paid to the history of military operations as part of the model design process. Clay Thomas's paper presented at {JCHAMP} rings true today with both its imperatives and cautionary notes about using historical data.},
	pages = {47--53},
	number = {3},
	journaltitle = {Military Operations Research},
	shortjournal = {Military Operations Research},
	date = {2002-06-01},
	keywords = {ndu library},
}

