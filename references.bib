@report{noauthor_publications_nodate,
	title = {Publications and Other Records,   1917 - 1945},
	rights = {Unrestricted},
	url = {http://research.archives.gov/description/4215115},
	abstract = {This series contains military publications and other records, including various intelligence reports collected by the Military Intelligence Division ({MID}).  A number of reports relate to Cuba and Mexico in the early 20th century.  These country studies include information about industry and commerce, agriculture, military fortifications, roads and railroads, cities and towns, public works, and natural resources.

The series contains a number of albums of photographs relating to Cuba; compiled by the Cuba Company, and intelligence staff attached to the United States Army of Cuban Pacification, 1906-1909.  The photographs cover bridges, railroads, military facilities, harbors, public works, cities and towns, and prominent personalities.

The series contains copies of General Staff papers 2, 3, and 5 of Bulletins of Military Notes, 1903-1905.  The bulletins contain information about the military forces of various foreign countries, including Austria-Hungary, Brazil, China, Spain, Sweden, etc.

Finally, the series contains copies of Navy Pacific Theater World War {II} intelligence reports; as well as 1941 U.S. Army personnel reports.},
