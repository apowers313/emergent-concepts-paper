@article{pani_mental_1996,
	title = {Mental Imagery as the Adaptationist Views It},
	volume = {5},
	issn = {1053-8100},
	url = {http://www.sciencedirect.com/science/article/pii/S1053810096900203},
	doi = {10.1006/ccog.1996.0020},
	abstract = {Mental images are one of the more obvious aspects of human conscious experience. Familiar idioms such as “the mind's eye” reflect the high status of the image in metacognition. Theoretically, a defining characteristic of mental images is that they can be analog representations. But this has led to an enduring puzzle in cognitive psychology: How do “mental pictures” fit into a general theory of cognition? Three empirical problems have constituted this puzzle: The incidence of mental images has been unpredictable, innumerable ordinary concepts cannot be depicted, and images typically do not resemble things well. I argue in this paper that theorists have begun to address these problems successfully. I argue further that the critical theoretical framework involves thinking of mental images as information within a cognitive system that is fundamentally adaptive. The main outline of the adaptationist framework was evident in the school of thought known as American Functionalism, but adaptationism has formed a consistent pattern of theorizing across many authors and decades. I briefly describe Functionalism and then present seven basic claims about imagery that were common in the years before the predominance of behaviorism. I then show how these claims have reappeared and been further articulated in modern cognitive psychology. I end with a brief integration of some of the basic elements of an adaptationist theory of imagery.},
	pages = {288--326},
	number = {3},
	journaltitle = {Consciousness and Cognition},
	shortjournal = {Consciousness and Cognition},
	author = {Pani, John R.},
	urldate = {2017-07-17},
	date = {1996-09-01},
}

