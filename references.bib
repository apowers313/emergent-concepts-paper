@book{ph.d_future_2010,
	edition = {1 edition},
	title = {Future War: Non-Lethal Weapons in Modern Warfare},
	shorttitle = {Future War},
	abstract = {The nature of warfare has changed!  Like it or not, terrorism has established a firm foothold worldwide.  Economics and environmental issues are inextricably entwined on a global basis and tied directly to national regional security.  Although traditional threats remain, new, shadowy, and mercurial adversaries are emerging, and identifying and locating them is difficult.  Future War, based on the hard-learned lessons of Bosnia, Haiti, Somalia, Panama, and many other trouble spots, provides part of the solution.Non-lethal weapons are a pragmatic application of force, not a peace movement.  Ranging from old rubber bullets and tear gas to exotic advanced systems that can paralyze a country, they are essential for the preservation of peace and stability.  Future War explains exactly how non-lethal electromagnetic and pulsed-power weapons, the laser and tazer, chemical systems, computer viruses, ultrasound and infrasound, and even biological entities will be used to stop enemies.  These are the weapons of the future.},
	pagetotal = {272},
	publisher = {Thomas Dunne Books},
	author = {Ph.D, John B. Alexander and Clancy, Tom},
	date = {2010-04-01},
	keywords = {ndu library},
}

