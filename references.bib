@article{iba_how_2011,
	title = {How to Write Tacit Knowledge as a Pattern Language: Media Design for Spontaneous and Collaborative Communities},
	volume = {26},
	issn = {1877-0428},
	url = {http://www.sciencedirect.com/science/article/pii/S1877042811023883},
	doi = {10.1016/j.sbspro.2011.10.561},
	series = {The 2nd Collaborative Innovation Networks Conference - {COINs}2010},
	shorttitle = {How to Write Tacit Knowledge as a Pattern Language},
	abstract = {In this paper, we propose a procedure for making a pattern language, which describes the tacit knowledge of problem solving and problem finding in a certain domain, by collaboration among people who all have tacit knowledge for the target domain more or less. To demonstrate the procedure, we present our experience of making Learning Patterns, which is a pattern language for creative learning. Then, we discuss the importance of visual representation in pattern languages, and show our examples of illustration. We anticipate that our study opens the discussion for a new methodology for designing media for spontaneous and collaborative communities.},
