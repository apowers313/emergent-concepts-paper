@incollection{kralemann_semantics_2013,
	title = {The Semantics of Models: A Semiotic Philosophy of Science Approach},
	rights = {©2013 Springer-Verlag Berlin Heidelberg},
	isbn = {978-3-642-36007-7, 978-3-642-36008-4},
