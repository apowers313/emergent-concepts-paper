@article{gossner_complexity_2003,
	title = {On the Complexity of Coordination},
	volume = {28},
	issn = {0364-765X},
	url = {http://www.jstor.org/stable/4126994},
	abstract = {Many results on repeated games played by finite automata rely on the complexity of the exact implementation of a coordinated play of length n. For a large proportion of sequences, this complexity appears to be no less than n. We study the complexity of a coordinated play when allowing for a few mismatches. We prove the existence of a constant C such that if (m ln m)/n ≥ C, for almost any sequence of length n, there exists an automaton of size m that achieves a coordination ratio close to 1 with it. Moreover, we show that one can take any constant C such that C {\textgreater} e{\textbar}X{\textbar} ln {\textbar}X{\textbar}, where {\textbar}X{\textbar} is the size of the alphabet from which the sequence is drawn. Our result contrasts with Neyman (1997) that shows that when (m ln m)/n is close to 0, for almost no sequence of length n there exists an automaton of size m that achieves a coordination ratio significantly larger 1/{\textbar}X{\textbar} with it.},
	pages = {127--140},
	number = {1},
	journaltitle = {Mathematics of Operations Research},
	author = {Gossner, Olivier and Hernández, Penélope},
	urldate = {2011-09-19},
	date = {2003},
	note = {{ArticleType}: research-article / Full publication date: Feb., 2003 / Copyright © 2003 {INFORMS}},
