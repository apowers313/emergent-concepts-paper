@article{shultz_rules_1982,
	title = {Rules of Causal Attribution},
	volume = {47},
	issn = {0037-976X},
	url = {http://www.jstor.org/stable/1165893},
	doi = {10.2307/1165893},
	abstract = {Classical and recent conceptual analyses of causation are examined in order to identify various rules of causal attribution. A series of five experiments are reported which support the proposition that observers between 3 years and adulthood interpret physical causation primarily in terms of the concept of generative transmission rather than in terms of other well-known rules such as covariation, similarity, and temporal and spatial contiguity. The experiments sample a variety of physical phenomena, both familiar and unfamiliar, and include subjects from both traditional and Western cultures. Humean and Piagetian approaches to causal inference are related to the present findings, and possible developmental origins of causal concepts are discussed.},
	pages = {1--51},
	number = {1},
	journaltitle = {Monographs of the Society for Research in Child Development},
	author = {Shultz, Thomas R.},
	urldate = {2011-11-30},
