@report{noauthor_top_nodate,
	title = {Top Secret Correspondence Relating to Mobilization Plans,   1922 - 1942},
	rights = {Unrestricted},
	url = {http://research.archives.gov/description/2843277},
	abstract = {This series contains copies of contingency plans for military conflicts developed by the Joint Army-Navy Board, predecessor to the Joint Chiefs of Staff.  The records were maintained by the War Plans Division.

The Color Plans subseries contains plans for conflicts with specific nations.  Included are copies of  Plan Brown (Philippines), Plan Gray (Central America and the Caribbean), a second Plan Gray (Azores), Plan Green (Mexico), Plan Orange (Japan), Plan Purple (South America), Plan Red (Great Britain), Plan Red-Orange (Great Britain-Japan), Plan Tan (Cuba), and Plan Yellow (China).

The Color Plans subseries also contains copies of two plans relating to the United States of America, Plan Blue (Peacetime Preparedness) and Plan White (Domestic Emergency).  Finally, this subseries contains copies of plans relating to geographic areas, rather than specific nations, Rainbow Plans 1-5.

The Quickfire Plans subseries contains copies of Joint Operation Plan Quickfire and Quickfire 2.  Quickfire was developed as an alternative to Operation Torch, the British-American invasion of French North Africa.  The records provide details of the Quickfire plans, which called for U.S. forces to relieve British forces in Syria and Cypress, and to engage in a build-up of forces for eventual offensive action.},
	institution = {War Department},
	urldate = {2011-11-29},
	note = {{HMS}/{MLR} Entry Number: {NM}84 282
Declassification Project Number: {NND} 750027
Container {ID}: Boxes 265-280
Size: 7 linear feet
Record Level: Series
Material Type: Textual Records
Media Type: Paper
Alternate Title(s): Top Secret Correspondence Relating to Mobilization Plans ("Color" and "Quickfire"), 1922-1942
Institution: War Department. War Plans Division. (02/09/1918 - 03/23/1942)
Date Compiled: 1922 - 1942},
}

