@collection{thibault_art_1985,
	edition = {First edition. edition},
	title = {The Art and Practice of Military Strategy},
	abstract = {This book serves as the basic strategy text at the the National War College and is designed to be helpful to anyone interested in a comprehensive university-level course in military strategy or who wishes simply to review the ideas of military strategy.

The course and this text begin by laying a philosophical foundation with key passages from strategists like Clausewitz, Mahan, and Douhet in the art of war. They then proceed to examine the relevancy of the strategists' ideas to the three level of warfare. Some ideas apply to only one level, but others clearly apply across the spectrum of warfare. Although it is possible to begin one's study at either end of the spectrum, i.e., insurgency or strategic nuclear, we believe that the very existence if nuclear weapons influences how we think about war at any level...},
