@article{ashby_neuropsychological_1998,
	title = {A neuropsychological theory of multiple systems in category learning},
	volume = {105},
	issn = {0033-295X},
	doi = {10.1037/0033-295x.105.3.442},
	abstract = {A neuropsychological theory is proposed that assumes category learning is a competition between separate verbal and implicit (i.e., procedural-learning-based) categorization systems. The theory assumes that the caudate nucleus is an important component of the implicit system and that the anterior cingulate and prefrontal cortices are critical to the verbal system. In addition to making predictions for normal human adults, the theory makes specific predictions for children, elderly people, and patients suffering from Parkinson's disease, Huntington's disease, major depression, amnesia, or lesions of the prefrontal cortex. Two separate formal descriptions of the theory are also provided. One describes trial-by-trial learning, and the other describes global dynamics. The theory is tested on published neuropsychological data and on category learning data with normal adults.},
	pages = {442--481},
	number = {3},
	journaltitle = {Psychological Review},
	shortjournal = {Psychol Rev},
	author = {Ashby, F. G. and Alfonso-Reese, L. A. and Turken, A. U. and Waldron, E. M.},
	date = {1998-07},
	pmid = {9697427},
	keywords = {Adult, Aged, Amnesia, Caudate Nucleus, Child, Preschool, Depressive Disorder, Gyrus Cinguli, Humans, Huntington Disease, Learning Disabilities, Neuropsychological Tests, Parkinson Disease, Prefrontal Cortex},
}

@article{lamberts_array_1996,
	title = {Array Models of Cognition: William K. Estes (1994),Classification and Cognition. New York: Oxford Univ. Press. Pp. viii+272+index.},
	volume = {40},
	issn = {0022-2496},
	url = {https://www.sciencedirect.com/science/article/pii/S0022249696900255},
	doi = {10.1006/jmps.1996.0025},
	shorttitle = {Array Models of Cognition},
	abstract = {William K. Estes is Professor Emeritus at Harvard University, where he has been associated with the Department of Psychology since 1979. One of his primary recent research interests is categorization and classification. His extensive honors and awards include being a Member of the National Academy of Sciences, a Fellow of the American Academy of Arts and Sciences, a Guggenheim Fellow, and a recipient of the American Psychological Foundation Gold Medal for Lifetime Achievement in Psychological Science. His contributions to the profession of psychology include being a past editor {ofJournal} of Comparative and Physiological Psychology,Psychological Review, {andPsychological} Science. Koen Lamberts is a lecturer at the School of Psychology, University of Birmingham. His primary research interests are process models of categorization and object recognition. He has just edited (with D. Shanks) the {bookKnowledge}, Concepts, and Categories(University College London Press).},
	pages = {271--274},
