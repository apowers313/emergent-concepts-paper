@article{mingers_management_2008,
	title = {Management knowledge and knowledge management: realism and forms of truth},
	volume = {6},
	issn = {1477-8238, 1477-8246},
	url = {http://link.springer.com/article/10.1057/palgrave.kmrp.8500161},
	doi = {10.1057/palgrave.kmrp.8500161},
	shorttitle = {Management knowledge and knowledge management},
	abstract = {This paper addresses the issue of truth and knowledge in management generally and knowledge management in particular. Based on ideas from critical realism and critical theory, it argues against the monovalent conceptualization of knowledge implicitly or explicitly held by many authors and aims instead to develop a characterization that recognizes the rich and varied ways in which human beings may be said ‘to know’. It points out and conceptualizes a fundamental dimension of knowledge that is generally ignored or cursorily treated within the literature, that is, ‘truth’. It identifies four forms of knowledge – propositional, experiential, performative and epistemological – and explores their characteristics, especially in terms of truth and validity. It points out some implications for knowledge management.},
	pages = {62--76},
	number = {1},
	journaltitle = {Knowledge Management Research \& Practice},
	shortjournal = {Knowl Manage Res Pract},
	author = {Mingers, John},
	urldate = {2016-06-30},
