@article{tversky_advances_1992,
	title = {Advances in prospect theory: Cumulative representation of uncertainty},
	volume = {5},
	issn = {1573-0476},
	url = {https://doi.org/10.1007/BF00122574},
	doi = {10.1007/BF00122574},
	shorttitle = {Advances in prospect theory},
	abstract = {We develop a new version of prospect theory that employs cumulative rather than separable decision weights and extends the theory in several respects. This version, called cumulative prospect theory, applies to uncertain as well as to risky prospects with any number of outcomes, and it allows different weighting functions for gains and for losses. Two principles, diminishing sensitivity and loss aversion, are invoked to explain the characteristic curvature of the value function and the weighting functions. A review of the experimental evidence and the results of a new experiment confirm a distinctive fourfold pattern of risk attitudes: risk aversion for gains and risk seeking for losses of high probability; risk seeking for gains and risk aversion for losses of low probability.},
	pages = {297--323},
	number = {4},
	journaltitle = {Journal of Risk and Uncertainty},
	shortjournal = {J Risk Uncertainty},
	author = {Tversky, Amos and Kahneman, Daniel},
	urldate = {2023-01-08},
	date = {1992-10-01},
	langid = {english},
	keywords = {cumulative prospect theory},
}

@inproceedings{tversky_rational_1989,
	location = {Berlin, Heidelberg},
	title = {Rational Choice and the Framing of Decisions},
	isbn = {9783642749193},
	doi = {10.1007/978-3-642-74919-3_4},
	series = {{NATO} {ASI} Series},
	abstract = {Alternative descriptions of a decision problem often give rise to different preferences, contrary to the principle of invariance that underlines the rational theory of choice. Violations of this theory are traced to the rules that govern the framing of decision and to the psychological principles of evaluation embodied in prospect theory. Invariance and dominance are obeyed when their application is transparent and often violated in other situations. Because these rules are normatively essential but descriptively invalid, no theory of choice can be both normatively adequate and descriptively accurate.},
	pages = {81--126},
	publisher = {Springer},
	author = {Tversky, Amos and Kahneman, Daniel},
	editor = {Karpak, Birsen and Zionts, Stanley},
	date = {1989},
	langid = {english},
	keywords = {American Economic Review, Canonical Representation, Loss Aversion, Prospect Theory, Stochastic Dominance},
}

