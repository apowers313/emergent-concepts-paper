}

@incollection{wisniewski_concepts_2002,
	title = {Concepts and Categorization},
	rights = {Copyright © 2002 by John Wiley \& Sons, Inc. All rights reserved.},
	isbn = {9780471214427},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/0471214426.pas0211},
	abstract = {Traditionally, concepts have been viewed as mental representations that enable people to categorize or pick out a group of nonidentical but equivalent things (e.g., a concept of dog allows one to categorize many entities as “dogs” even though they are not identical). This chapter provides a broad overview of the fields of concepts and categorization, describing early research but giving special attention to work published in the last 15 years. It describes different views of the structure of human concepts (i.e., what they consist of), as well as formal mathematical models of categorization and category learning. These models assume that categorization is based on how similar an entity is to other members of the empirical category. This chapter describes research addressing the sufficiency of this approach, which suggests that similarity is a dynamic process involving the comparison of complex mental representations, and that category learning involves the integration of empirical learning with background knowledge. The chapter also examines research describing the taxonomic and thematic organization of concepts in memory. Finally, the chapter addresses the functions that concepts serve beyond their traditional role in classification.},
	booktitle = {Stevens' Handbook of Experimental Psychology},
	publisher = {John Wiley \& Sons, Ltd},
	author = {Wisniewski, Edward J.},
	urldate = {2023-11-15},
	date = {2002},
	langid = {english},
	doi = {10.1002/0471214426.pas0211},
	keywords = {categorization, category learning, concept, exemplar model, prototype model, similarity},
}

