@article{vetere_memory_2019,
	title = {Memory formation in the absence of experience {\textbar} Nature Neuroscience},
	volume = {22},
	issn = {1546-1726},
	url = {https://www.nature.com/articles/s41593-019-0389-0},
	doi = {10.1038/s41593-019-0389-0},
	abstract = {Memory is coded by patterns of neural activity in distinct circuits. Therefore, it should be possible to reverse engineer a memory by artificially creating these patterns of activity in the absence of a sensory experience. In olfactory conditioning, an odor conditioned stimulus ({CS}) is paired with an unconditioned stimulus ({US}; for example, a footshock), and the resulting {CS}–{US} association guides future behavior. Here we replaced the odor {CS} with optogenetic stimulation of a specific olfactory glomerulus and the {US} with optogenetic stimulation of distinct inputs into the ventral tegmental area that mediate either aversion or reward. In doing so, we created a fully artificial memory in mice. Similarly to a natural memory, this artificial memory depended on {CS}–{US} contingency during training, and the conditioned response was specific to the {CS} and reflected the {US} valence. Moreover, both real and implanted memories engaged overlapping brain circuits and depended on basolateral amygdala activity for expression.},
	pages = {933--940},
	number = {6},
	journaltitle = {Nature Neuroscience},
	author = {Vetere, Gisella and Tran, Lina M. and Moberg, Sara and Steadman, Patrick E. and Restivo, Leonardo and Morrison, Filomene G. and Ressler, Kerry J. and Josselyn, Sheena A. and Frankland, Paul W.},
	urldate = {2022-12-26},
	date = {2019-06},
}

@article{nadel_memory_2012,
	title = {Memory formation, consolidation and transformation},
	volume = {36},
	issn = {0149-7634},
	url = {https://www.sciencedirect.com/science/article/pii/S0149763412000437},
	doi = {10.1016/j.neubiorev.2012.03.001},
	series = {Memory Formation},
	abstract = {Memory formation is a highly dynamic process. In this review we discuss traditional views of memory and offer some ideas about the nature of memory formation and transformation. We argue that memory traces are transformed over time in a number of ways, but that understanding these transformations requires careful analysis of the various representations and linkages that result from an experience. These transformations can involve: (1) the selective strengthening of only some, but not all, traces as a function of synaptic rescaling, or some other process that can result in selective survival of some traces; (2) the integration (or assimilation) of new information into existing knowledge stores; (3) the establishment of new linkages within existing knowledge stores; and (4) the up-dating of an existing episodic memory. We relate these ideas to our own work on reconsolidation to provide some grounding to our speculations that we hope will spark some new thinking in an area that is in need of transformation.},
	pages = {1640--1645},
	number = {7},
	journaltitle = {Neuroscience \& Biobehavioral Reviews},
	shortjournal = {Neuroscience \& Biobehavioral Reviews},
	author = {Nadel, L. and Hupbach, A. and Gomez, R. and Newman-Smith, K.},
	urldate = {2022-12-26},
	date = {2012-08-01},
	langid = {english},
	keywords = {Memory consolidation, Reconsolidation, Transformation},
}

