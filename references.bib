@report{noauthor_situation_nodate,
	title = {Situation Maps,   12/22/1941 - 05/04/1945},
	rights = {Unrestricted},
	url = {http://research.archives.gov/description/1135967},
	abstract = {This series consists of daily situation maps showing Allied ground and air operations in various theaters during World War {II}. Ground operations include the Philippine Islands, North Africa, Sicily, Pantelleria, Southern France, and Italy. These maps include information on Allied and Axis troop dispositions and the location of the front line. Troop locations are identified at the Army, Corps, and Division level. Also included are brief descriptions of key events, such as significant offensive and defensive battles, aerial bombing attacks, and local naval activity. The maps also show the locations of towns, roads, railroads, and rivers.

Additional situation maps detail Allied air operations in the European and Mediterranean theaters. These maps show the daily location of significant activity, mostly bombing operations, and include a brief description detailing the number of bombers and fighter planes involved, the type and degree of enemy opposition encountered, a target description and bombing results, and any losses or damage to aircraft.},
	institution = {War Department},
	urldate = {2011-12-07},
	note = {Size: 820 maps
Record Level: Series
Material Type: Maps and Charts
Media Type: Paper
General Note: Beginning in January 1945, situation maps illustrating European Air Operations were created by Supreme Headquarters Allied Expeditionary Force. These maps can be found in the series "Situation Maps, 12/1/1944-4/30/1945" ({ARC} Identifier 1136007).
Institution: War Department. Military Intelligence Division. (08/26/1918 - 04/19/1947)
Subjects: Air warfare, Europe, France (Europe) nation, Italy (Europe) nation, North Africa (Africa) region (general), Pantelleria, Isola di (Trapani, Sicily, Italy, Europe) island, Philippines (Asia) nation, Sicily (Italy, Europe) region, World War, 1939-1945
