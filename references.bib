@book{little_managing_2005,
	location = {Thousand Oaks, {CA}},
	edition = {2nd edition},
	title = {Managing Knowledge: An Essential Reader},
	isbn = {978-1-4129-1240-2},
	shorttitle = {Managing Knowledge},
	abstract = {Knowledge management is crucial to organizational learning, innovation and success within organizations. The Second Edition of the successful knowledge management reader provides a core source of key theoretical thinkers in the field and presents the most up-to-date leading-edge articles that explore emerging trends. A comprehensive introduction places these readings in context and draws together key strands across the field. The new reader includes new and revised chapters as well as newly authored material, to provide students with a current resource that enables the study of knowledge management from a variety of perspectives. Theoretical work and engaging case studies place knowledge management in the context of an emerging global economy.},
