@article{milton_bloombaum_doing_1970,
	title = {Doing Smallest Space Analysis},
	volume = {14},
	issn = {0022-0027},
	url = {http://www.jstor.org/stable/173520},
	abstract = {The basic question addressed by smallest space analysis ({SSA}) is "What is the smallest space in which a body of data may be adequately represented?" For some social science research problems, {SSA} has advantages over a technique like factor analysis, at the same time that it serves somewhat similar purposes. The procedure is explained and a comparative illustration is given using R. J. Rummel's data on the attributes of 14 nations, where factor analysis was used (cf. Rummel, this journal, December 1967). Among a number of useful features of {SSA} discussed in the paper are the following: it offers a geometric output to render the structure of a body of data easily comprehensible; it gives the smallest number of dimensions; it provides a measure of "goodness of fit;" output may be checked directly against input table; and {SSA} is available as part of a standard library of computerized programs.},
