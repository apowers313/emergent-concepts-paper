@incollection{ladyman_structural_2014,
	edition = {Spring 2014},
	title = {Structural Realism},
	url = {http://plato.stanford.edu/archives/spr2014/entries/structural-realism/},
	abstract = {Structural realism is considered by many realists and antirealistsalike as the most defensible form of scientific realism. There are nowmany forms of structural realism and an extensive literature aboutthem. There are interesting connections with debates in metaphysics,philosophy of physics and philosophy of mathematics. This entry isintended to be a comprehensive survey of the field.},
