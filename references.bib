@article{mahoney_resource-based_2001,
	title = {A resource-based theory of sustainable rents},
	volume = {27},
	issn = {0149-2063, 1557-1211},
	url = {http://ezproxy.sfpl.org/login?url=http://search.ebscohost.com/login.aspx?direct=true&db=bth&AN=5777199},
	doi = {10.1177/014920630102700603},
	abstract = {This paper summarizes and comments on Conner (1991) that contributes to the strategic management area by providing an historical comparison of resource-based theory and five schools of thought within industrial organization economics. Conner (1991) argues that the fundamental distinction between resource-based theory and transaction costs theory is that resource-based theory focuses on the deployment and combination of specific inputs while transaction costs theory focuses on the avoidance of opportunism. I offer three responses to this claim. First, Conner’s distinction was not central to the resource-based literature at the time the article was published. Second, I raise concerns about building a resource-based theory of the firm that assumes away the problems of opportunistic behavior. Third, I offer an alternative view of the fundamental similarities and differences between resource-based theory and transaction costs theory.},
	pages = {651--660},
	number = {6},
	journaltitle = {Journal of Management},
	shortjournal = {Journal of Management},
	author = {Mahoney, Joseph T.},
	urldate = {2014-07-29},
	date = {2001-11},
	langid = {english},
}

@article{williamson_strategy_1999,
	title = {Strategy Research: Governance and Competence Perspectives},
	volume = {20},
	rights = {Copyright © 1999 Wiley},
	issn = {0143-2095},
	url = {http://www.jstor.org.ezproxy.sfpl.org/stable/3094080},
	shorttitle = {Strategy Research},
	abstract = {Business strategy is a complex subject and is usefully examined from several perspectives. This paper applies the lenses of governance and competence to the study of strategy. Both the governance and the competence perspectives have had the benefit of distinguished antecedents. They have also had to deal with tautological reputations. I begin with the governance perspective, with emphasis on the six key moves through which it has been operationalized. I then examine the competence perspective in these same six respects. Governance challenges the competence perspective to apply itself more assiduously to operationalization, including the need to choose and give definition to one or more units of analysis (of which the 'routine' is a promising candidate). The research challenges posed by competence to which governance can and should respond include dynamic transaction costs, learning, and the need to push beyond generic governance to address strategy issues faced by particular firms (with their distinctive strengths and disabilities). A lively research future for these two perspectives, individually and in combination, is projected.},
	pages = {1087--1108},
	number = {12},
	journaltitle = {Strategic Management Journal},
	shortjournal = {Strategic Management Journal},
	author = {Williamson, Oliver E.},
	urldate = {2014-09-29},
	date = {1999-12-01},
}

