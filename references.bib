@book{langacker_cognitive_2008,
	location = {Oxford ; New York},
	edition = {1 edition},
	title = {Cognitive Grammar: A Basic Introduction},
	isbn = {9780195331967},
	shorttitle = {Cognitive Grammar},
	abstract = {This book fills a long standing need for a basic introduction to Cognitive Grammar that is current, authoritative, comprehensive, and approachable.  It presents a synthesis that draws together and refines the descriptive and theoretical notions developed in this framework over the course of three decades.  In a unified manner, it accommodates both the conceptual and the social-interactive basis of linguistic structure, as well as the need for both functional explanation and explicit structural description. Starting with the fundamentals, essential aspects of the theory are systematically laid out with concrete illustrations and careful discussion of their rationale. Among the topics surveyed are conceptual semantics, grammatical classes, grammatical constructions, the lexicon-grammar continuum characterized as assemblies of symbolic structures (form-meaning pairings), and the usage-based account of productivity, restrictions, and well-formedness.  The theory's central claim - that grammar is inherently meaningful - is thereby shown to be viable. The framework is further elucidated through application to nominal structure, clause structure, and complex sentences. These are examined in broad perspective, with exemplification from English and numerous other languages. In line with the theory's general principles, they are discussed not only in terms of their structural characterization, but also their conceptual value and functional motivation.  Other matters explored include discourse, the temporal dimension of language structure, and what grammar reveals about cognitive processes and the construction of our mental world.},
	pagetotal = {584},
	publisher = {Oxford University Press},
	author = {Langacker, Ronald W.},
	date = {2008-02-04},
}

@book{langacker_foundations_1999,
	location = {Stanford, Calif},
	edition = {1 edition},
	title = {The Foundations of Cognitive Grammar: Volume I: Theoretical Prerequisites},
	isbn = {9780804738514},
	shorttitle = {The Foundations of Cognitive Grammar},
	abstract = {This is the first volume of a two-volume work that introduces a new and fundamentally different conception of language structure and linguistic investigation. The central claim of cognitive grammar is that grammar forms a continuum with lexicon and is fully describable in terms of symbolic units (i.e. form-meaning pairings). In contrast to current orthodoxy, the author argues that grammar is not autonomous with respect to semantics, but rather reduces to patterns for the structuring and symbolization of conceptual content.},
	pagetotal = {540},
	publisher = {Stanford University Press},
	author = {Langacker, Ronald},
	date = {1999-08-01},
}

