@article{shosteck_shopping_1975,
	title = {Shopping, Voting, and Media Preference},
	volume = {15},
	issn = {00218499},
	url = {http://ezproxy.sfpl.org/login?url=http://search.ebscohost.com/login.aspx?direct=true&db=bth&AN=5228389},
	abstract = {The article describes the function of media research in identifying media preferences of a target market. Media research is distinguished from general market research that may determine consumer interest in a product, the advertising message that can best sell it, or the demographic characteristics of the consumers to whom the product is best directed. Together with these traditional research concerns, parallel media research can also be directed at identifying the media choices that will most efficiently reach the target market. In its most basic form the required media research entails a representative survey of the market. The attraction of such media research rests in its simple adaptation to current market-research methodology. Its application requires no more attention to the requirements of problem definition, questionnaire construction, code development, analysis formation, population choice, sample definition, and others, inherent in any professional survey research. The essential differences lie in the questions asked on viewing, listening and reading habits and the subsequent analysis of their relationships to respondent preference for the product being marketed. The required questions can be incorporated into any ongoing market research study. The additional cost is minimal. The return in relevant advertising information can be substantial.},
	pages = {35--38},
	number = {6},
	journaltitle = {Journal of Advertising Research},
	shortjournal = {Journal of Advertising Research},
	author = {Shosteck, Herschel},
	urldate = {2014-09-19},
	date = {1975-12},
}

