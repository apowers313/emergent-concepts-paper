@article{smith_pattern_2011,
	title = {The Pattern Instance Notation: A simple hierarchical visual notation for the dynamic visualization and comprehension of software patterns},
	volume = {22},
	issn = {1045-926X},
	url = {http://www.sciencedirect.com/science/article/pii/S1045926X11000188},
	doi = {10.1016/j.jvlc.2011.03.003},
	shorttitle = {The Pattern Instance Notation},
	abstract = {Design patterns are a common tool for developers and architects to understand and reason about a software system. Visualization techniques for patterns tend to be either highly theoretical in nature or based on a structural view of a system's implementation. The Pattern Instance Notation is a simple notation technique for visualizing design patterns and other abstractions of software engineering. While based on a formal representation of design patterns, {PIN} is a tool for comprehension or reasoning which requires no formal training or study, and it is suitable for the programmer or designer without a theoretical background. {PIN} is hierarchical in nature and compactly encapsulates abstractions that may be spread widely across a system in a concise graphical format, while allowing for repeated unveiling of deeper layers of complexity and interaction on demand. It is designed to be used in either a dynamic visualization tool, or as a static representation for documentation and as a teaching aid.},
	pages = {355--374},
	number = {5},
	journaltitle = {Journal of Visual Languages \& Computing},
	shortjournal = {Journal of Visual Languages \& Computing},
	author = {Smith, Jason {McC}.},
	urldate = {2014-06-17},
	date = {2011-10},
}

@book{bahar_system_nodate,
	title = {System and Systems Thinking:},
	shorttitle = {System and Systems Thinking},
	abstract = {"System" is a common word that is used in all fields of the human knowledge. Many people, without having an exact meaning of the word system in mind, use it more and more in their daily conversations or writings in some way. In this book, general and universal concepts and methods of system and systems thinking that are common in all fields of the human knowledge, are presented in a new form under the title of "System and Systems Thinking as a Fundamental Theory and Practice Framework". What are presented in this book, are the basic concepts so that as the pieces of a puzzle have completed each other as a whole in the form of a fundamental theory and practice framework based on the system and systems thinking concepts. We will see how by starting from the objects and related events and their governing orders and rules as the constant and variable aspects in the space and time of the world we are faced with, we can reach to the structures, behaviors and disciplines by the aid of matter, energy and information that dominate the things as systems in the world around us. Also it will be revealed that how the information like the matter and energy is among the basic necessities of the organic systems and why there is so much sensitivity and discussions about the free flow of information in human societies for example like the accessibility of matter in the form of any material thing and energy in the form of electricity for all humans. Because of the generality of the subject and its usefulness for a wide range of people, the content of this book is also good for teaching in a university interdisciplinary and organizational vocational course or work shop. For this purpose, in addition to this book (System and Systems Thinking - Book 1 - Fundamental Theory and Practice), "System and Systems Thinking – Book 2 - Teach and Work" is also available for the instructors and students who wish to use this book in a teaching course. So, this book (Book – 1) is an independent book for reading and Book – 2 is for the people who wish to use the concepts introduced in Book – 1, in practice.},
	pagetotal = {201},
	author = {Bahar, A. Gharakhani},
	keywords = {kindle},
}

