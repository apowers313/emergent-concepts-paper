@report{noauthor_records_nodate,
	title = {Records Relating to Psychological Warfare and Propaganda Activities in Overseas Theaters,   1939 - 1945},
	rights = {Unrestricted},
	url = {http://research.archives.gov/description/4657988},
	abstract = {This series contains reports and correspondence relating to psychological warfare and propaganda activities of Allied forces in various countries and theaters.  A number of reports relate to foreign attitudes about the United States, as well as the morale of foreign populations.  Most of the information for such reports was gleaned from prisoner of war ({POW}) and refugee interrogations.  To this end, the series contains copies of {POW} opinion polls and morale surveys.  Of note is a report, “Japanese Home Morale Under Bombing” (File: Japanese Morale Under Bombs). 

The series also contains daily and weekly surveys of propaganda efforts by Axis, Allied, and some neutral governments in their own countries (Files: Colonel Brewer's Daily Reports; Colonel Brewer's Weekly Reports, Colonel Brewer's Reports).  Reports also cover propaganda activities by front (Eastern, Western) theater (European, Pacific, Far Eastern) and some Axis occupied areas (Files: Colonel Brewer's Daily Reports; Colonel Brewer's Weekly Reports, Colonel Brewer's Reports).

Files also contain records about the creation and use of propaganda leafleting by the Allies, including examples of such leaflets.  Finally, the series contains reports about the government of Vichy France (File: Administration, Metropolitan France).},
	institution = {War Department},
	urldate = {2011-12-07},
	note = {{HMS}/{MLR} Entry Number: {NM}84 172
Declassification Project Number: {NND} 750122
Container {ID}: Boxes 1-19
