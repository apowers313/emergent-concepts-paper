@article{cartwright_empiricist_2000,
	title = {An empiricist defence of singular causes},
	volume = {46},
	issn = {1755-3555, 1358-2461},
	url = {https://www.cambridge.org/core/journals/royal-institute-of-philosophy-supplements/article/an-empiricist-defence-of-singular-causes/AB0E13CED2410ADA66F9C7E6BAA99B37},
	doi = {10.1017/S1358246100010365},
	abstract = {Empiricism has traditionally been concerned with two questions: (a) What is the source of our concepts and ideas? and (b) How should claims to empirical knowledge be judged? The empiricist answer to the first question is ‘From observation or experience.’ The concern in the second question is not to ground science in pure observation or in direct experience, but rather to ensure that claims to scientific knowledge are judged against the natural phenomena themselves. Questions about nature must be settled by nature — not by faith, nor metaphysics, nor mathematics, and not by convention or convenience either. From Francis Bacon to Karl Popper empiricists have wanted to police the methods of scientific enquiry.},
	pages = {47--58},
	journaltitle = {Royal Institute of Philosophy Supplements},
	author = {Cartwright, Nancy},
	urldate = {2016-10-15},
	date = {2000-03},
}

